{
  "name": "apod",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "dev": "npm-run-all --parallel sw:dev ionic-start",
    "start": "ng serve -o",
    "ionic-start": "ionic serve",
    "build": "ng build",
    "format": "npx prettier --write .",
    "postbuild": "npm run sw:build && bread-compressor dist/app",
    "serve-dist": "ws --hostname localhost -d dist/app -p 1234 -o --log.format stats",
    "lint": "ng lint",
    "pbts": "pbjs -t static-module --es6 -w es6 ../server/src/main/protobuf/Apod.proto -o src/app/protos/apod.js && pbts --no-comments src/app/protos/apod.js -o src/app/protos/apod.d.ts",
    "sw:dev": "rimraf ./src/service-worker.js && vite build --config ./vite.sw.config.mjs --mode development --watch",
    "sw:build": "rimraf ./dist/app/service-worker.js && vite build --config ./vite.sw.config.mjs --mode production && workbox injectManifest ./workbox-config.js"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/router": "21.2.15",
    "@ionic/angular": "8.8.8",
    "dexie": "4.4.3",
    "ionicons": "8.0.13",
    "protobufjs": "8.5.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "workbox-cacheable-response": "7.4.1",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "workbox-window": "7.4.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@eslint/js": "10.0.1",
    "@ionic/angular-toolkit": "12.3.0",
    "angular-eslint": "21.4.0",
    "bread-compressor-cli": "4.1.0",
    "eslint": "10.4.1",
    "local-web-server": "5.4.0",
    "npm-run-all": "4.1.5",
    "protobufjs-cli": "2.5.0",
    "rimraf": "6.1.3",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "workbox-cli": "7.4.1"
  }
}
